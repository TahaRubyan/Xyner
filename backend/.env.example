# Server configuration
PORT=3000

# Google Gemini API key (Get it from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Cloud API credentials
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
VERIFY_TOKEN=your_custom_webhook_verification_token_here

# Firebase Admin configuration
# Set this to "true" to run in local mock mode without a real Firebase service account JSON
USE_FIREBASE_MOCK=true
